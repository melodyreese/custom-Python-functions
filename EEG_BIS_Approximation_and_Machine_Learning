def estimate_lag(all_data_df, max_lag_sec=60):
    """
    Estimate the temporal offset between openibis and ground-truth BIS.
    The Aspect BIS monitor applies internal smoothing before exporting, so
    the ground-truth BIS trace lags behind instantaneous openibis scores.
    The lag is measured empirically and used only for QC visualisation.
    """
    step_sec       = EPOCH_STEP / FS   # 2.0 s
    max_lag_epochs = int(max_lag_sec / step_sec)

    clean = all_data_df[
        ~all_data_df['artifact'] & (all_data_df['bis_truth'] >= 0)
    ].dropna(subset=['bis_truth', 'bis_oib'])

    oib   = clean['bis_oib'].values   - clean['bis_oib'].mean()
    truth = clean['bis_truth'].values - clean['bis_truth'].mean()

    xcorr = np.correlate(oib, truth, mode='full')
    lags  = np.arange(-(len(truth) - 1), len(oib))
    mask  = (lags >= -max_lag_epochs) & (lags <= max_lag_epochs)

    best_idx   = np.argmax(xcorr[mask])
    lag_epochs = int(lags[mask][best_idx])
    lag_sec    = lag_epochs * step_sec
    norm       = np.sqrt(np.sum(oib**2) * np.sum(truth**2))
    xcorr_peak = xcorr[mask][best_idx] / (norm + 1e-10)
    print(f"  Estimated lag    : {lag_epochs:+d} epochs  ({lag_sec:+.0f} s)")
    print(f"  Interpretation   : openibis {'leads' if lag_epochs > 0 else 'lags'} "
          f"ground-truth BIS by {abs(lag_sec):.0f} s")
    print(f"  Normalised xcorr : {xcorr_peak:.3f} at peak")
    if lag_epochs > 0:
        print("  Consistent with Aspect monitor smoothing or output delay.")

    return lag_epochs, lag_sec, xcorr_peak


def apply_lag_correction(series, lag_epochs):
    """Shift openibis forward by lag_epochs; vacated positions become NaN."""
    arr       = np.array(series, dtype=float)
    corrected = np.full_like(arr, np.nan)
    if   lag_epochs == 0:  return arr
    elif lag_epochs  > 0:  corrected[:-lag_epochs] = arr[lag_epochs:]
    else:                  corrected[-lag_epochs:]  = arr[:lag_epochs]
    return corrected


def openibis_agreement_stats(all_data_df, lag_epochs=0):
    """
    Openibis vs ground-truth BIS agreement statistics (epoch- and sample-level).
    Sample-level: one openibis mean per ground-truth BIS monitor sample: 
    the correct unit for Bland-Altman (avoids inflating n by ~2.5x).
    """
    clean = all_data_df[
        ~all_data_df['artifact'] & (all_data_df['bis_truth'] >= 0)
    ].dropna(subset=['bis_truth', 'bis_oib']).copy()

    def _stats(label, oib_vals, truth_vals):
        r_p, _ = pearsonr(truth_vals, oib_vals)
        r_s, _ = spearmanr(truth_vals, oib_vals)
        mae    = mean_absolute_error(truth_vals, oib_vals)
        diff   = oib_vals - truth_vals
        print(f"\n{label}")
        print(f"  n              : {len(oib_vals):,}")
        print(f"  Pearson r      : {r_p:.3f}")
        print(f"  Spearman rho   : {r_s:.3f}")
        print(f"  MAE            : {mae:.2f} BIS units")
        print(f"  B-A bias ± SD  : {diff.mean():.2f} ± {diff.std():.2f}")
        return r_p, r_s, mae, diff

    r_p_ep, r_s_ep, mae_ep, diff_ep = _stats(
        "Epoch-level (ground-truth BIS repeated ~2.5× per monitor sample):",
        clean['bis_oib'].values, clean['bis_truth'].values)

    # Sample-level: average openibis across epochs sharing the same BIS sample
    ds_rows = []
    for _, grp in clean.groupby('case'):
        grp   = grp.reset_index(drop=True)
        block = (grp['bis_truth'] != grp['bis_truth'].shift()).cumsum()
        for _, blk in grp.groupby(block):
            ds_rows.append({
                'bis_truth': blk['bis_truth'].iloc[0],
                'bis_oib':   blk['bis_oib'].mean(),
            })
    ds_df = pd.DataFrame(ds_rows)

    r_p_ds, r_s_ds, mae_ds, diff_ds = _stats(
        "Sample-level (one openibis mean per ground-truth BIS sample — for B-A):",
        ds_df['bis_oib'].values, ds_df['bis_truth'].values)

    print(f"{'═'*65}")

    if lag_epochs == 0:
        return (r_p_ep, r_s_ep, mae_ep, diff_ep,
                r_p_ds, r_s_ds, mae_ds, diff_ds,
                None, None, None, None, ds_df)

    oib_corr = apply_lag_correction(clean['bis_oib'].values, lag_epochs)
    valid    = ~np.isnan(oib_corr)
    r_p_lc, r_s_lc, mae_lc, diff_lc = _stats(
        f"Epoch-level lag-corrected (+{lag_epochs} epochs / +{lag_epochs*2} s):",
        oib_corr[valid], clean['bis_truth'].values[valid])

    return (r_p_ep, r_s_ep, mae_ep, diff_ep,
            r_p_ds, r_s_ds, mae_ds, diff_ds,
            r_p_lc, r_s_lc, mae_lc, diff_lc, ds_df)


def plot_bland_altman(ds_df, lag_epochs=0, save=True):
    """Figure 3: Bland-Altman plot (sample-level, with optional lag-corrected panel)."""
    n_panels = 2 if lag_epochs != 0 else 1
    fig, axes = plt.subplots(1, n_panels, figsize=(7 * n_panels, 5), squeeze=False)
    fig.suptitle('Bland-Altman: Openibis vs Ground-Truth BIS', fontsize=13)

    def _ba_panel(ax, oib_vals, truth_vals, title):
        diff = oib_vals - truth_vals
        mean = (oib_vals + truth_vals) / 2
        md, sd = diff.mean(), diff.std()
        ax.scatter(mean, diff, s=8, alpha=0.30, color='steelblue')
        ax.axhline(0,            color='gray',   lw=1,   ls=':')
        ax.axhline(md,           color='red',    lw=2,   label=f'Bias = {md:.1f}')
        ax.axhline(md + 1.96*sd, color='orange', lw=1.5, ls='--',
                   label=f'+1.96 SD = {md+1.96*sd:.1f}')
        ax.axhline(md - 1.96*sd, color='orange', lw=1.5, ls='--',
                   label=f'−1.96 SD = {md-1.96*sd:.1f}')
        ax.set_title(title, fontsize=10)
        ax.set_xlabel('Mean of openibis and Ground-Truth BIS')
        ax.set_ylabel('openibis − Ground-Truth BIS')
        ax.legend(fontsize=9)

    _ba_panel(axes[0, 0],
              ds_df['bis_oib'].values, ds_df['bis_truth'].values,
              'openibis approximation vs Ground-Truth BIS\n'
              '(one openibis mean per monitor sample)')

    if lag_epochs != 0:
        oib_corr = apply_lag_correction(ds_df['bis_oib'].values, lag_epochs)
        valid    = ~np.isnan(oib_corr)
        _ba_panel(axes[0, 1],
                  oib_corr[valid], ds_df['bis_truth'].values[valid],
                  f'Lag-corrected (+{lag_epochs} epochs / +{lag_epochs*2} s)')

    plt.tight_layout()
    if save:
        plt.savefig(os.path.join(RESULTS_DIR, 'fig3_bland_altman.png'),
                    dpi=130, bbox_inches='tight')
        print("[plot] Saved: fig3_bland_altman.png")
    plt.show()


