def openibis_threshold_classifier(all_data_df):
    """
    Step 4a baseline: classify depth of anesthesia by applying the same
    BIS thresholds to openibis scores — no machine learning involved.
    This is the reference performance for the ML models to beat.
    """
    valid = all_data_df[
        ~all_data_df['artifact'] &
        (all_data_df['bis_truth'] >= 0) &
        all_data_df['cat_truth'].notna()
    ].copy()
    valid['cat_oib_thresh'] = valid['bis_oib'].apply(
        lambda b: CATEGORIES[bis_to_cat(b)])

    y_true  = valid['cat_truth'].values.astype(int)
    y_pred  = valid['cat_oib_thresh'].values.astype(int)
    present = sorted(set(y_true))
    labels  = [CAT_LABELS[i] for i in present]

    acc                    = accuracy_score(y_true, y_pred)
    prec, rec, f1, _       = precision_recall_fscore_support(
        y_true, y_pred, labels=present, average='macro', zero_division=0)

    print("(BIS cut-points applied directly to openibis scores; no ML)")
    print(f"Accuracy           : {acc:.3f}")
    print(f"Precision (macro)  : {prec:.3f}")
    print(f"Recall (macro)     : {rec:.3f}")
    print(f"F1 (macro)         : {f1:.3f}")
    print(classification_report(y_true, y_pred, labels=present,
                                target_names=labels, zero_division=0))
    print(f"{'═'*65}")
    return acc, prec, rec, f1


def run_xgb_loocv(all_data_df, feature_cols, model_name):
    """
    Case-level leave-one-out cross-validation (LOOCV).

    For each fold: train on N=23 cases, evaluate on the held-out case.
    Label: cat_truth (ground-truth BIS depth category).
    Clean epochs only (no artifact, no sentinel BIS values).
    """
    valid = all_data_df[
        ~all_data_df['artifact'] & (all_data_df['bis_truth'] >= 0)
    ].dropna(subset=feature_cols + ['cat_truth'])

    cases     = sorted(valid['case'].unique())
    all_preds = []

    print(f"\n{'═'*65}")
    print(f"{model_name} — Case-Level LOOCV ({len(cases)} folds)")
    print(f"{'─'*65}")

    for test_case in cases:
        train = valid[valid['case'] != test_case]
        test  = valid[valid['case'] == test_case]
        if train.empty or test.empty:
            continue

        X_tr = train[feature_cols].values
        y_tr = train['cat_truth'].values.astype(int)
        X_te = test[feature_cols].values
        y_te = test['cat_truth'].values.astype(int)

        scaler   = StandardScaler()
        X_tr     = scaler.fit_transform(X_tr)
        X_te     = scaler.transform(X_te)

        clf = XGBClassifier(
            n_estimators=200, max_depth=5, learning_rate=0.05,
            subsample=0.8, colsample_bytree=0.8,
            eval_metric='mlogloss', random_state=42, verbosity=0,
        )
        clf.fit(X_tr, y_tr)

        y_pred  = clf.predict(X_te)
        y_proba = clf.predict_proba(X_te)
        acc     = accuracy_score(y_te, y_pred)
        print(f"  {test_case:<14}  n={len(y_te):>5}  acc={acc:.3f}")

        res = test[['case', 'bis_truth', 'bis_oib', 'cat_truth', 'cat_oib']].copy()
        res['cat_pred'] = y_pred
        for j, lbl in enumerate(CAT_LABELS):
            res[f'prob_{lbl}'] = y_proba[:, j] if j < y_proba.shape[1] else np.nan
        all_preds.append(res)

    return pd.concat(all_preds, ignore_index=True), clf


def report_performance(pred_df, model_name, baseline_acc):
    """Print classification metrics for one XGBoost model."""
    y_true  = pred_df['cat_truth'].values.astype(int)
    y_pred  = pred_df['cat_pred'].values.astype(int)
    present = sorted(set(y_true))
    labels  = [CAT_LABELS[i] for i in present]

    acc              = accuracy_score(y_true, y_pred)
    prec, rec, f1, _ = precision_recall_fscore_support(
        y_true, y_pred, labels=present, average='macro', zero_division=0)

    prob_cols = [f'prob_{l}' for l in CAT_LABELS if f'prob_{l}' in pred_df.columns]
    auc = (roc_auc_score(y_true, pred_df[prob_cols].values,
                         multi_class='ovr', average='macro', labels=present)
           if len(prob_cols) >= len(present) else np.nan)

    print(f"{model_name} PERFORMANCE (LOOCV vs ground-truth BIS)")
    print(f"Accuracy           : {acc:.3f}  (openibis baseline: {baseline_acc:.3f})")
    print(f"ROC-AUC (macro OvR): {auc:.3f}")
    print(f"Precision (macro)  : {prec:.3f}")
    print(f"Recall (macro)     : {rec:.3f}")
    print(f"F1 (macro)         : {f1:.3f}")
    print(classification_report(y_true, y_pred, labels=present,
                                target_names=labels, zero_division=0))
    print(f"{'═'*65}")
    return acc, auc, prec, rec, f1


