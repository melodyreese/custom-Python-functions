def descriptive_stats(all_data_df):
    """Per-case QC table: epoch counts, artifact rates, and BIS distributions."""
    rows = []
    for case, grp in all_data_df.groupby('case'):
        clean  = grp[~grp['artifact'] & (grp['bis_truth'] >= 0)]
        n_neg  = int((grp['bis_truth'] < 0).sum())
        if clean.empty:
            continue
        q1, q3 = np.percentile(clean['bis_truth'], [25, 75])
        rows.append({
            'Case':             case,
            'N epochs':         len(grp),
            'N artifact':       int(grp['artifact'].sum()),
            'N bis<0':          n_neg,
            'Pct clean':        round(100 * len(clean) / len(grp), 1),
            'BIS mean':         round(clean['bis_truth'].mean(), 1),
            'BIS median':       round(clean['bis_truth'].median(), 1),
            'BIS SD':           round(clean['bis_truth'].std(), 1),
            'BIS min':          round(clean['bis_truth'].min(), 1),
            'BIS Q1':           round(q1, 1),
            'BIS Q3':           round(q3, 1),
            'BIS max':          round(clean['bis_truth'].max(), 1)})

    df = pd.DataFrame(rows).set_index('Case')
    print(df.to_string())
    return df


