# ══════════════════════════════════════════════════════════════════════════════
# Openibis Implementation
# Runs on raw EEG with no preprocessing, no smoothing, accurate to the published algorithm.
# ══════════════════════════════════════════════════════════════════════════════

def band_power_db(psd, freqs, fmin, fmax):
    """Mean PSD in a frequency band, in dB (re 1 µV²/Hz)."""
    mask = (freqs >= fmin) & (freqs <= fmax)
    bp   = np.mean(psd[mask]) if mask.sum() > 0 else 1e-10
    return 10 * np.log10(bp + 1e-10)


def detect_burst_suppression(epoch, abs_threshold_uv=5.0, min_suppress_ms=500):
    """
    Burst suppression ratio (BSR) using a 5 µV absolute amplitude threshold.
    Contiguous runs of at least min_suppress_ms where |amplitude| < 5 µV are
    counted as suppressed. Returns the fraction of the epoch in suppression.
    Note: the Aspect BIS monitor uses a proprietary multi-parameter BSR
    algorithm (Connor 2025, OpenBSR); this is a clinical approximation.
    """
    min_samps  = int(min_suppress_ms / 1000 * FS)
    suppressed = (np.abs(epoch) < abs_threshold_uv).astype(int)
    n_sup, in_run, run_len = 0, False, 0
    for s in suppressed:
        if s:
            in_run   = True
            run_len += 1
        else:
            if in_run and run_len >= min_samps:
                n_sup += run_len
            in_run   = False
            run_len  = 0
    if in_run and run_len >= min_samps:
        n_sup += run_len
    return n_sup / len(epoch)


def logistic_response(x, x50, slope):
    return 100 / (1 + np.exp(slope * (x - x50)))


def openibis_epoch(epoch, x50_ga=-5.0):
    """Compute the openibis score for a single 4-second epoch."""
    freqs, psd = signal.periodogram(epoch, fs=FS, window='hann')

    db_total = band_power_db(psd, freqs, 0.5, 47)
    db_low   = band_power_db(psd, freqs, 0.5,  4)
    db_mid   = band_power_db(psd, freqs, 11,  20)
    db_vhigh = band_power_db(psd, freqs, 40,  47)

    ga_comp  = db_vhigh - db_total     # high-frequency relative power
    sed_comp = db_mid   - db_total     # spindle-band relative power

    score_ga  = logistic_response(ga_comp,  x50=x50_ga, slope=-0.5)
    score_sed = logistic_response(sed_comp, x50=0,      slope=-0.6)

    bsr       = detect_burst_suppression(epoch)
    score_bsr = 100 * (1 - bsr)

    # GA-sedation combination rule (Connor 2022, Eq. 3)
    if score_ga < score_sed:
        combined = 0.5 * (score_sed + score_ga) if (db_low - db_mid) <= 5 else score_ga
    else:
        combined = score_sed

    provisional = 0.7 * combined + 0.3 * score_bsr

    # Non-linear end-cap scaling (Connor 2022, Eq. 4)
    if   provisional <= 10: final = 10 * (provisional / 10) ** 0.5
    elif provisional >= 97: final = 97 + 3 * ((provisional - 97) / 3) ** 2
    else:                   final = provisional

    return float(np.clip(final, 0, 100))


def openibis_epoch_components(epoch, x50_ga=-5.0):
    """Return all intermediate sub-scores for diagnostic inspection."""
    freqs, psd = signal.periodogram(epoch, fs=FS, window='hann')

    db_total = band_power_db(psd, freqs, 0.5, 47)
    db_low   = band_power_db(psd, freqs, 0.5,  4)
    db_mid   = band_power_db(psd, freqs, 11,  20)
    db_vhigh = band_power_db(psd, freqs, 40,  47)

    ga_comp  = db_vhigh - db_total
    sed_comp = db_mid   - db_total

    score_ga  = logistic_response(ga_comp,  x50=x50_ga, slope=-0.5)
    score_sed = logistic_response(sed_comp, x50=0,      slope=-0.6)

    bsr       = detect_burst_suppression(epoch)
    score_bsr = 100 * (1 - bsr)

    if score_ga < score_sed:
        combined = 0.5 * (score_sed + score_ga) if (db_low - db_mid) <= 5 else score_ga
    else:
        combined = score_sed

    provisional = 0.7 * combined + 0.3 * score_bsr

    if   provisional <= 10: final = 10 * (provisional / 10) ** 0.5
    elif provisional >= 97: final = 97 + 3 * ((provisional - 97) / 3) ** 2
    else:                   final = provisional

    return {
        'ga_comp': ga_comp, 'sed_comp': sed_comp,
        'score_ga': score_ga, 'score_sed': score_sed,
        'bsr': bsr, 'score_bsr': score_bsr,
        'combined': combined, 'final': float(np.clip(final, 0, 100))}


def calibrate_x50_ga(cases):
    """
    Estimate the dataset-specific GA logistic midpoint (x50_ga).
    Connor's original x50_ga = -5 was calibrated on a 12-patient Brigham
    dataset. Different EEG hardware shifts absolute gamma-band power, pushing
    ga_comp into the logistic floor and collapsing every score to ~30.
    Setting x50_ga = median(ga_comp) across all epochs centers the logistic
    on this dataset while preserving function shape.
    """
    ga_comps = []
    for eeg, bis, meta in cases:
        n_steps = (len(eeg) - EPOCH_SAMP) // EPOCH_STEP + 1
        for i in range(n_steps):
            epoch      = eeg[i*EPOCH_STEP : i*EPOCH_STEP + EPOCH_SAMP]
            freqs, psd = signal.periodogram(epoch, fs=FS, window='hann')
            db_total   = band_power_db(psd, freqs, 0.5, 47)
            db_vhigh   = band_power_db(psd, freqs, 40,  47)
            ga_comps.append(db_vhigh - db_total)

    x50_ga = float(np.median(ga_comps))
    print("  Connor 2022 original x50_ga : -5.00")
    print(f"  This dataset median ga_comp : {x50_ga:.2f}")
    print(f"  Adopted x50_ga              : {x50_ga:.2f}")
    print("  Rationale: centers the GA logistic on observed gamma-band")
    return x50_ga


def run_openibis(eeg, x50_ga=-5.0):
    """Run openibis on raw EEG; returns one score per 2 s (50% overlap)."""
    n_steps = (len(eeg) - EPOCH_SAMP) // EPOCH_STEP + 1
    return np.array([
        openibis_epoch(eeg[i*EPOCH_STEP : i*EPOCH_STEP + EPOCH_SAMP], x50_ga=x50_ga)
        for i in range(n_steps)
    ])


