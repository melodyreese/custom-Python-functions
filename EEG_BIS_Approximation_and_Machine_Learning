def load_case(path):
    """Load EEG and BIS vectors from a .mat file (HDF5 format)."""
    import h5py
    with h5py.File(path, 'r') as f:
        eeg = np.array(f['EEG']).flatten().astype(float)
        bis = np.array(f['bis']).flatten().astype(float)

    dur_sec      = len(eeg) / FS
    bis_interval = dur_sec / len(bis)

    return eeg, bis, {
        'case':             os.path.basename(path),
        'eeg_samples':      len(eeg),
        'bis_samples':      len(bis),
        'eeg_dur_sec':      round(dur_sec, 1),
        'bis_interval_sec': round(bis_interval, 2),
        'bis_rate_hz':      round(1.0 / bis_interval, 3),
        'ratio_eeg_bis':    round(len(eeg) / len(bis), 1)}


def load_all_cases(data_dir):
    """Load all case*.mat files and print a data characterisation table."""
    paths = sorted(glob.glob(os.path.join(data_dir, 'case*.mat')))
    if not paths:
        raise FileNotFoundError(f"No case*.mat files found in '{data_dir}'")

    cases, rows = [], []
    for path in paths:
        eeg, bis, meta = load_case(path)
        cases.append((eeg, bis, meta))
        rows.append(meta)

    df = pd.DataFrame(rows).set_index('case')

    mean_int = df['bis_interval_sec'].mean()
    std_int  = df['bis_interval_sec'].std()
    print(f"\n  BIS interval: {mean_int:.2f} ± {std_int:.2f} s across cases")
    print(f"  EEG/BIS ratio: {df['ratio_eeg_bis'].mean():.1f} "
          f"(expected {int(EXPECTED_BIS_SEC * FS)} at {EXPECTED_BIS_SEC} s interval)")

    outliers = df[np.abs(df['bis_interval_sec'] - EXPECTED_BIS_SEC) > 1.0]
    if not outliers.empty:
        print("\n  WARNING: cases with BIS interval >1 s from expected:")
        print(outliers[['bis_interval_sec', 'ratio_eeg_bis']].to_string())
    else:
        print(f"\n  All cases consistent with ~{EXPECTED_BIS_SEC} s BIS export interval")
    return cases, df


