def main():
    parser = argparse.ArgumentParser(
        description='EEG BIS Pipeline — openibis (Connor 2022) + XGBoost LOOCV')
    parser.add_argument('--data_dir',    default=DATA_DIR)
    parser.add_argument('--max_lag_sec', type=float, default=60.0)
    parser.add_argument('--no_plot',     action='store_true')
    args = parser.parse_args()

    # ── Load and inspect raw EEG data ────────────────────────────────
    cases, _ = load_all_cases(args.data_dir)

    if not args.no_plot:
        eeg0, _, meta0 = cases[0]
        plot_raw_eeg(eeg0, meta0['case'])

    # ── Openibis implementation ──────────────────────────────────────
    # Calibrate the GA logistic midpoint to this dataset before processing
    print("\n[calibration] Estimating ga_comp median for x50_ga recalibration...")
    x50_ga = calibrate_x50_ga(cases)

    print("\n[processing] Running openibis and extracting EEG features for all cases...")
    all_frames = []
    for eeg, bis, meta in cases:
        print(f"  {meta['case']}...", end=' ', flush=True)
        df    = process_case(eeg, bis, meta, x50_ga=x50_ga)
        n_rej = int(df['artifact'].sum())
        print(f"{len(df)} epochs, {n_rej} rejected ({100*n_rej/len(df):.1f}%)")
        all_frames.append(df)

    all_data_df = pd.concat(all_frames, ignore_index=True)
    all_data_df.to_csv(os.path.join(RESULTS_DIR, 'all_epochs.csv'), index=False)

    # Optional: inspect openibis sub-component distributions
    print("\n[diagnostic] Computing openibis sub-components (first 5 cases)...")
    comp_df = pd.DataFrame([
        {**openibis_epoch_components(
            eeg[i*EPOCH_STEP : i*EPOCH_STEP + EPOCH_SAMP], x50_ga=x50_ga),
         'case': meta['case']}
        for eeg, _, meta in cases[:5]
        for i in range((len(eeg) - EPOCH_SAMP) // EPOCH_STEP + 1)])
    if not args.no_plot:
        plot_openibis_components(comp_df)

    # ── Quality control ───────────────────────────────────────────────
    desc_df = descriptive_stats(all_data_df)
    desc_df.to_csv(os.path.join(RESULTS_DIR, 'descriptive_stats.csv'))
    save_cohort_tables(all_data_df, desc_df)
    save_bis_descriptive_stats(all_data_df)

    if not args.no_plot:
        plot_bis_distributions(all_data_df)

    # Cross-lag estimation and Bland-Altman agreement
    lag_epochs, lag_sec, _ = estimate_lag(all_data_df, max_lag_sec=args.max_lag_sec)

    (r_p_ep, r_s_ep, mae_ep, diff_ep,
     r_p_ds, r_s_ds, mae_ds, diff_ds,
     r_p_lc, r_s_lc, mae_lc, diff_lc,
     ds_df) = openibis_agreement_stats(all_data_df, lag_epochs=lag_epochs)

    if not args.no_plot:
        plot_bland_altman(ds_df, lag_epochs=lag_epochs)

    # ── Openibis threshold baseline classifier ───────────────────────
    oib_acc, oib_prec, oib_rec, oib_f1 = openibis_threshold_classifier(all_data_df)

    # ── XGBoost — openibis scores only ───────────────────────────────
    print("XGBoost classifier: openibis scores only")
    pred_df_oib, _ = run_xgb_loocv(
        all_data_df, OPENIBIS_ONLY_FEATURES, 'XGBoost (openibis-only)')
    pred_df_oib.to_csv(
        os.path.join(RESULTS_DIR, 'predictions_openibis_only.csv'), index=False)

    acc_oib, auc_oib, prec_oib, rec_oib, f1_oib = report_performance(
        pred_df_oib, 'XGBoost (openibis-only)', baseline_acc=oib_acc)

    # ── XGBoost — EEG features + openibis ─────────────────
    print("XGBoost classifier: EEG spectral features + openibis")
    pred_df_full, clf_last_fold = run_xgb_loocv(
        all_data_df, EEG_AND_OPENIBIS_FEATURES, 'XGBoost (EEG + openibis)')
    pred_df_full.to_csv(
        os.path.join(RESULTS_DIR, 'predictions_eeg_openibis.csv'), index=False)

    acc_full, auc_full, prec_full, rec_full, f1_full = report_performance(
        pred_df_full, 'XGBoost (EEG + openibis)', baseline_acc=oib_acc)

    # ── Feature importance on model refit to all data ────────────
    clf_final = fit_final_model(all_data_df, EEG_AND_OPENIBIS_FEATURES)
    fi_df = pd.DataFrame({
        'Feature':    EEG_AND_OPENIBIS_FEATURES,
        'Importance': clf_final.feature_importances_,
    }).sort_values('Importance', ascending=False)
    fi_df.to_csv(os.path.join(RESULTS_DIR, 'feature_importance.csv'), index=False)
    print("\n[saved] Feature importance table → feature_importance.csv")

    # ── FINAL SUMMARY ─────────────────────────────────────────────────────────
    print(f"  {'Method':<38} {'Metric':<25} {'Value'}")
    rows = [
        ('openibis agreement (sample-level)', 'Pearson r',        f'{r_p_ds:.3f}'),
        ('openibis agreement (sample-level)', 'Spearman rho',     f'{r_s_ds:.3f}'),
        ('openibis agreement (sample-level)', 'MAE (BIS units)',  f'{mae_ds:.2f}'),
        ('openibis agreement (sample-level)', 'B-A bias ± SD',    f'{diff_ds.mean():.2f} ± {diff_ds.std():.2f}')]
    if lag_epochs != 0 and r_p_lc is not None:
        rows += [
            (f'openibis (+{lag_sec:.0f}s lag-corrected)', 'Pearson r',    f'{r_p_lc:.3f}'),
            (f'openibis (+{lag_sec:.0f}s lag-corrected)', 'Spearman rho', f'{r_s_lc:.3f}'),
            (f'openibis (+{lag_sec:.0f}s lag-corrected)', 'MAE',          f'{mae_lc:.2f}')]
    rows += [
        ('openibis threshold',      'Accuracy',         f'{oib_acc:.3f}'),
        ('openibis threshold',      'Precision (macro)',f'{oib_prec:.3f}'),
        ('openibis threshold',      'Recall (macro)',   f'{oib_rec:.3f}'),
        ('openibis threshold',      'F1 (macro)',       f'{oib_f1:.3f}'),
        ('XGBoost openibis-only',   'Accuracy',         f'{acc_oib:.3f}'),
        ('XGBoost openibis-only',   'ROC-AUC (macro)',  f'{auc_oib:.3f}'),
        ('XGBoost openibis-only',   'Precision (macro)',f'{prec_oib:.3f}'),
        ('XGBoost openibis-only',   'Recall (macro)',   f'{rec_oib:.3f}'),
        ('XGBoost openibis-only',   'F1 (macro)',       f'{f1_oib:.3f}'),
        ('XGBoost EEG + openibis',  'Accuracy',         f'{acc_full:.3f}'),
        ('XGBoost EEG + openibis',  'ROC-AUC (macro)',  f'{auc_full:.3f}'),
        ('XGBoost EEG + openibis',  'Precision (macro)',f'{prec_full:.3f}'),
        ('XGBoost EEG + openibis',  'Recall (macro)',   f'{rec_full:.3f}'),
        ('XGBoost EEG + openibis',  'F1 (macro)',       f'{f1_full:.3f}')]
    for method, metric, val in rows:
        print(f"  {method:<38} {metric:<25} {val}")
    print(f"{'═'*72}")


    if not args.no_plot:
        plot_summary(all_data_df, pred_df_oib, pred_df_full, clf_final,
                     lag_epochs=lag_epochs)

