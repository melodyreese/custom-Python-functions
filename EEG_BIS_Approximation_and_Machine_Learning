# EEG Preprocessing and Feature Extraction
# The openibis algorithm runs on raw EEG. This additional EEG feature set
# uses separately preprocessed data.
# ══════════════════════════════════════════════════════════════════════════════

def preprocess_eeg(eeg, notch_freq=60.0, bp_low=0.5, bp_high=47.0, order=4):
    """Apply bandpass (0.5–47 Hz) and 60 Hz notch filter to raw EEG."""
    nyq     = FS / 2.0
    b_bp, a_bp = signal.butter(order, [bp_low / nyq, bp_high / nyq], btype='band')
    eeg_f   = signal.filtfilt(b_bp, a_bp, eeg)
    b_n, a_n   = signal.iirnotch(notch_freq / nyq, Q=30)
    return signal.filtfilt(b_n, a_n, eeg_f)


def spectral_edge_frequency(psd, freqs, edge=0.95):
    """Frequency below which edge fraction of total power is contained."""
    total = np.sum(psd)
    if total == 0:
        return 0.0
    cumulative = np.cumsum(psd) / total
    idx = np.searchsorted(cumulative, edge)
    return float(freqs[min(idx, len(freqs) - 1)])


def permutation_entropy(epoch, order=3, delay=1):
    """Normalised permutation entropy (EEG complexity measure)."""
    all_perms = {p: i for i, p in enumerate(iperms(range(order)))}
    counts    = {}
    for i in range(len(epoch) - delay * (order - 1)):
        key = all_perms[tuple(np.argsort(epoch[i : i + delay * order : delay]))]
        counts[key] = counts.get(key, 0) + 1
    probs = np.array(list(counts.values()), dtype=float)
    probs /= probs.sum()
    return float(-np.sum(probs * np.log2(probs + 1e-10)) / np.log2(math.factorial(order)))


def extract_features(epoch):
    """
    Extract spectral and complexity features from preprocessed EEG epochs.

    Features:
      - Band power (dB): delta, theta, alpha, beta, low-gamma, high-gamma, total
      - Band power ratios: delta/beta, delta/alpha, alpha/beta, low-gamma/delta
      - Spectral edge frequency: SEF50, SEF95
      - Permutation entropy (complexity)
      - Burst suppression ratio (BSR)
    """
    freqs, psd = signal.periodogram(epoch, fs=FS, window='hann')

    def bp(lo, hi):
        return band_power_db(psd, freqs, lo, hi)

    bp_d   = bp(0.5,  4)
    bp_th  = bp(4,    8)
    bp_al  = bp(8,   13)
    bp_be  = bp(13,  30)
    bp_lg  = bp(30,  40)
    bp_hg  = bp(40,  47)
    bp_tot = bp(0.5, 47)

    return {
        # Absolute band powers
        'bp_delta':           bp_d,
        'bp_theta':           bp_th,
        'bp_alpha':           bp_al,
        'bp_beta':            bp_be,
        'bp_low_gamma':       bp_lg,
        'bp_high_gamma':      bp_hg,
        'bp_total':           bp_tot,
        # Band power ratios (log-domain differences)
        'ratio_delta_beta':   bp_d  - bp_be,
        'ratio_delta_alpha':  bp_d  - bp_al,
        'ratio_alpha_beta':   bp_al - bp_be,
        'ratio_lgamma_delta': bp_lg - bp_d,
        # Spectral edge frequencies
        'sef95':              spectral_edge_frequency(psd, freqs, edge=0.95),
        'sef50':              spectral_edge_frequency(psd, freqs, edge=0.50),
        # Complexity / suppression
        'perm_entropy':       permutation_entropy(epoch),
        'bsr':                detect_burst_suppression(epoch)}


def build_feature_matrix(eeg_filtered):
    """
    Extract one feature vector per 4 s epoch (50% overlap, same grid as openibis).
    Epochs with any sample exceeding the artifact threshold are flagged and
    set to NaN (excluded from ML training and evaluation).
    """
    n_steps       = (len(eeg_filtered) - EPOCH_SAMP) // EPOCH_STEP + 1
    rows, artifact_mask = [], np.zeros(n_steps, dtype=bool)
    _keys = None

    for i in range(n_steps):
        epoch = eeg_filtered[i*EPOCH_STEP : i*EPOCH_STEP + EPOCH_SAMP]
        if np.any(np.abs(epoch) > ARTIFACT_THRESH_UV):
            artifact_mask[i] = True
            if _keys is None:
                _keys = list(extract_features(epoch).keys())
            rows.append({k: np.nan for k in _keys})
        else:
            feats = extract_features(epoch)
            if _keys is None:
                _keys = list(feats.keys())
            rows.append(feats)

    return pd.DataFrame(rows), artifact_mask


def align_bis_to_epochs(bis, n_epochs, bis_interval_sec):
    """
    Map each epoch index to the nearest ground-truth BIS sample.
    Effective epoch step = EPOCH_STEP / FS = 2 s (both openibis and ML paths).
    """
    step_sec       = EPOCH_STEP / FS
    epochs_per_bis = bis_interval_sec / step_sec
    idx = np.array([min(int(i / epochs_per_bis), len(bis) - 1) for i in range(n_epochs)])
    return bis[idx]


def process_case(eeg, bis, meta, x50_ga=-5.0):
    """
    Process one case through both the openibis and ML feature extraction paths.

    Both paths use 4-second epochs with 50% overlap (one output every 2 s).
    openibis runs on raw EEG; ML features are extracted from filtered EEG.
    Ground-truth BIS values < 0 are excluded from QC and classification 
    but do not affect the openibis or feature extraction.
    """
    bis_interval = meta['bis_interval_sec']

    # openibis path: raw EEG
    oib_scores  = run_openibis(eeg, x50_ga=x50_ga)
    n_ep        = len(oib_scores)
    aligned_bis = align_bis_to_epochs(bis, n_ep, bis_interval)

    # ML feature path: preprocessed EEG
    features_df, art_mask = build_feature_matrix(preprocess_eeg(eeg))

    # Align to shortest (should all be equal; clip for safety)
    n_ep = min(n_ep, len(aligned_bis), len(features_df))
    features_df = features_df.iloc[:n_ep].copy()
    art_mask    = art_mask[:n_ep]
    oib_scores  = oib_scores[:n_ep]
    aligned_bis = aligned_bis[:n_ep]

    features_df['bis_oib']   = oib_scores
    features_df['bis_truth'] = aligned_bis
    features_df['cat_oib']   = [CATEGORIES[bis_to_cat(b)] for b in oib_scores]
    features_df['cat_truth'] = [
        CATEGORIES[bis_to_cat(b)] if b >= 0 else np.nan for b in aligned_bis
    ]
    features_df['artifact']  = art_mask
    features_df['case']      = meta['case']

    return features_df


