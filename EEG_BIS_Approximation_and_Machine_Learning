def bis_to_cat(bis):
    """Map a BIS value to its depth-of-anesthesia category label"""
    if   bis >= 80: return 'awake'
    elif bis >= 60: return 'sedated'
    elif bis >= 40: return 'anesthetized'
    else:           return 'deep/BS'


